# ═══════════════════════════════════════════════════════════════
#  TrustGuard — AI Fraud Detection System
#  .gitignore — whozahm3d/trustguard-ai-fraud-detection
# ═══════════════════════════════════════════════════════════════
#
#  RULE: commit everything EXCEPT datasets, secrets, and caches.
#  Specifically committed:
#    app.py, deployment.ipynb, rag_module.py, requirements.txt
#    deliverable_1_and_2_pipeline.ipynb, rag_system.ipynb
#    .streamlit/config.toml
#    outputs/  (all subfolders — models, metrics, plots, ablation, rag, experiments, deployment)
#    chroma_db/
#    SBP_Documents/
# ═══════════════════════════════════════════════════════════════


